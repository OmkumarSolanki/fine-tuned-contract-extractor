# Hugging Face — optional. If unset, the data pipeline falls back to the public
# unsloth/Meta-Llama-3.1-8B-Instruct mirror, which ships an identical chat template.
HF_TOKEN=

# Langfuse observability (Phase 9) — optional. If the keys are unset, the serving
# layer runs with tracing disabled (no-op) and requests still succeed. Set all
# three to send per-request latency/throughput/token traces to your Langfuse
# project. LANGFUSE_HOST is optional (defaults to Langfuse Cloud); set it for a
# self-hosted instance, e.g. http://localhost:3000.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
