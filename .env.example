# Hugging Face — optional. If unset, the data pipeline falls back to the public
# unsloth/Meta-Llama-3.1-8B-Instruct mirror, which ships an identical chat template.
HF_TOKEN=

# Langfuse observability (Phase 9) — optional. If the keys are unset, the serving
# layer runs with tracing disabled (no-op) and requests still succeed. Set all
# three to send per-request latency/throughput/token traces to your Langfuse
# project. LANGFUSE_HOST is optional (defaults to Langfuse Cloud); set it for a
# self-hosted instance, e.g. http://localhost:3000.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Serving (Phase 8/11) — optional.
# EXTRACTOR_ADAPTER_PATH: LoRA adapter the API loads at startup. Defaults to the
# local training output (checkpoints/contract-extractor/final-adapter); set it to
# the published Hub repo to serve without any local weights. The Docker image
# defaults this to the Hub repo already.
EXTRACTOR_ADAPTER_PATH=solankiom/llama-3.1-8b-contract-extractor

# EXTRACTOR_API_KEY: simple API-key auth for /extract and /extract/stream. When
# UNSET, the endpoints are open (local dev/demo). When set, clients must send a
# matching `X-API-Key` header or get 401. /health stays open either way.
EXTRACTOR_API_KEY=
